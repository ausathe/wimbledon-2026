---
/* "Show courts" toggle + legend container (URS-12, URS-13, URS-47). */
---

<div class="controls">
  <button
    type="button"
    class="courts-toggle"
    id="courts-toggle"
    aria-pressed="false"
    aria-controls="courts-legend"
  >
    Show courts
  </button>
  <ul
    class="courts-legend"
    id="courts-legend"
    role="listbox"
    aria-label="Show courts"
    aria-multiselectable="true"
  >
  </ul>
</div>
